# ============================================================
#  AGENTS-HQ — API Keys Template
#  Copy to: agent_01_osint/.env and fill in your keys.
#  All agents fall back to agent_01_osint/.env automatically.
# ============================================================

# ── Agent-08 News Intel ───────────────────────────────────────
# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=

# ── Agent-09 Market Intel ────────────────────────────────────
# Finnhub — https://finnhub.io (free tier)
FINNHUB_API_KEY=

# ── Agent-10 Dark Web Monitor ────────────────────────────────
# IntelligenceX — https://intelx.io (free key available)
INTELX_API_KEY=

# Have I Been Pwned — https://haveibeenpwned.com/API/Key
# (only needed for per-account lookups — public breaches work without key)
HIBP_API_KEY=

# ── Agent-06 Ghidra RE ───────────────────────────────────────
# VirusTotal — https://www.virustotal.com/gui/join-us
VT_API_KEY=

# ── Alert System (P5) ────────────────────────────────────────────────────────
# Webhook — fires a POST with JSON payload on CRITICAL findings
# Works with Slack, Discord, or any custom HTTP endpoint
ALERT_WEBHOOK_URL=

# SMTP email — send alerts via any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── Infrastructure (docker-compose reads from .env in project root) ──────────
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=agents_hq
MYSQL_USER=agents
MYSQL_PASSWORD=change_me
